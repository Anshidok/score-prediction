rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // match config: anyone may read; only the server (Admin SDK) writes.
    // Admin SDK bypasses these rules, so client writes are always denied here.
    match /config/match {
      allow read: if true;
      allow write: if false;
    }

    function matchUnlocked() {
      // open unless: doc missing (open), manually locked, or kickoff time passed.
      // data.get(key, default) avoids an error when a field is absent;
      // missing kickoff defaults to year 2999 = effectively never auto-locks.
      let ref = /databases/$(database)/documents/config/match;
      return !exists(ref)
        || (get(ref).data.get('locked', false) != true
            && request.time < get(ref).data.get('kickoff', timestamp.date(2999, 1, 1)));
    }
    function iHavePredicted() {
      return request.auth != null
        && exists(/databases/$(database)/documents/predictions/$(request.auth.uid));
    }
    function realAccount() {
      // require a real (non-anonymous) sign-in so identity is one-per-person
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function validPrediction() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 40
        && d.h is int && d.h >= 0 && d.h <= 30
        && d.a is int && d.a >= 0 && d.a <= 30;
    }

    function validName() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 40;
    }

    // public name registry: anyone may read (so duplicates can be detected
    // before the prediction reveal gate opens); you may only claim your own.
    match /names/{userId} {
      allow read: if true;
      allow create, update: if realAccount()
        && request.auth.uid == userId
        && matchUnlocked()
        && validName();
      // cleared server-side (Admin SDK) alongside predictions
      allow delete: if false;
    }

    match /predictions/{userId} {
      // REVEAL GATE: you may read predictions only after you have submitted yours
      allow read: if iHavePredicted();

      // you may write only your own prediction, while the match is unlocked
      allow create, update: if realAccount()
        && request.auth.uid == userId
        && matchUnlocked()
        && validPrediction();

      // clearing predictions is done server-side (Admin SDK); clients cannot delete
      allow delete: if false;
    }
  }
}
